{
  "rules": {
    "user-roles": {
      ".read": false,
      ".write": false
    },
    "regional-chats": {
      ".read": "auth != null",
      "$region": {
        ".read": "auth != null",
        "messages": {
          "$messageId": {
            ".write": "auth != null && !data.exists() && newData.child('senderId').val() === auth.uid",
            ".validate": "newData.hasChildren(['senderId', 'senderName', 'senderRole', 'timestamp']) && (newData.child('text').exists() || newData.child('fileUrl').exists())",
            "senderId": {
              ".validate": "newData.val() === auth.uid"
            },
            "readBy": {
              "$uid": {
                ".write": "auth != null && $uid === auth.uid"
              }
            }
          }
        }
      }
    },
    "regional-announcements": {
      "$region": {
        ".read": "auth != null",
        "posts": {
          "$postId": {
            ".write": "auth != null && auth.token.executive_role === true && !data.exists() && newData.child('authorId').val() === auth.uid",
            ".validate": "newData.hasChildren(['authorId', 'authorName', 'authorRole', 'timestamp']) && (newData.child('text').exists() || newData.child('fileUrl').exists())",
            "authorId": {
              ".validate": "newData.val() === auth.uid"
            },
            "readBy": {
              "$uid": {
                ".write": "auth != null && $uid === auth.uid"
              }
            }
          }
        }
      }
    },
    "national-chat": {
      ".read": "auth != null && auth.token.executive_role === true",
      "messages": {
        "$messageId": {
          ".write": "auth != null && auth.token.executive_role === true && !data.exists() && newData.child('senderId').val() === auth.uid",
          ".validate": "newData.hasChildren(['senderId', 'senderName', 'senderRole', 'timestamp']) && (newData.child('text').exists() || newData.child('fileUrl').exists())",
          "senderId": {
            ".validate": "newData.val() === auth.uid"
          },
          "readBy": {
            "$uid": {
              ".write": "auth != null && $uid === auth.uid"
            }
          }
        }
      }
    }
  }
}
