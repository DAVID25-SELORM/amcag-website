rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Role helpers used across collections
    function hasRole(role) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isRole(role) {
      return hasRole(role);
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }
    
    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRegionName() {
      return currentUserData().keys().hasAny(['region']) ? currentUserData().region : '';
    }

    function userRegionId() {
      return currentUserData().keys().hasAny(['regionId']) ? currentUserData().regionId : '';
    }

    function userRegion() {
      return userRegionName() != '' ? userRegionName() : userRegionId();
    }

    function isSameRegion(region) {
      return isAuthenticated() && (
        region == userRegionName() ||
        region == userRegionId()
      );
    }

    function sameExecutiveRegion(record) {
      return isAuthenticated() && (
        (record.keys().hasAny(['region']) && isSameRegion(record.region)) ||
        (record.keys().hasAny(['regionId']) && isSameRegion(record.regionId))
      );
    }

    function executiveTitle() {
      return currentUserData().keys().hasAny(['executiveTitle']) ?
        currentUserData().executiveTitle :
        (currentUserData().keys().hasAny(['title']) ? currentUserData().title : '');
    }

    function hasPermission(permission) {
      return isAuthenticated() && (
        hasRole('super_admin') ||
        (
          currentUserData().keys().hasAny(['permissions']) &&
          currentUserData().permissions.get(permission, false) == true
        )
      );
    }

    function isNationalPresident() {
      return hasRole('national_executive') && executiveTitle() in ['president', 'President', 'PRESIDENT', 'National President'];
    }

    function isNationalSecretary() {
      return hasRole('national_executive') && executiveTitle() in ['secretary', 'Secretary', 'SECRETARY', 'National Secretary'];
    }

    function isNationalTreasurer() {
      return hasRole('national_executive') && executiveTitle() in ['treasurer', 'Treasurer', 'TREASURER', 'National Treasurer'];
    }

    function isRegionalPresident() {
      return hasRole('regional_executive') && executiveTitle() in ['president', 'President', 'PRESIDENT', 'Regional President'];
    }

    function isRegionalSecretary() {
      return hasRole('regional_executive') && executiveTitle() in ['secretary', 'Secretary', 'SECRETARY', 'Regional Secretary'];
    }

    function isRegionalTreasurer() {
      return hasRole('regional_executive') && executiveTitle() in ['treasurer', 'Treasurer', 'TREASURER', 'Regional Treasurer'];
    }

    function canManageMembers() {
      return hasRole('super_admin') ||
        isNationalPresident() ||
        isNationalSecretary() ||
        hasPermission('canManageMembers');
    }

    function canApproveMembers() {
      return hasRole('super_admin') ||
        isNationalPresident() ||
        isNationalSecretary() ||
        isRegionalPresident() ||
        isRegionalSecretary() ||
        hasPermission('canApproveMembers');
    }

    function canViewNationalPayments() {
      return hasRole('super_admin') ||
        isNationalPresident() ||
        isNationalTreasurer() ||
        hasPermission('canViewNationalPayments');
    }

    function canViewRegionalPayments() {
      return hasRole('super_admin') ||
        isNationalPresident() ||
        isNationalTreasurer() ||
        isRegionalPresident() ||
        isRegionalTreasurer() ||
        hasPermission('canViewRegionalPayments');
    }

    function canManagePayments() {
      return hasRole('super_admin') ||
        isNationalPresident() ||
        isNationalTreasurer() ||
        isRegionalTreasurer() ||
        hasPermission('canManagePayments');
    }

    function canManageExecutives() {
      return hasRole('super_admin') ||
        isNationalPresident() ||
        isRegionalPresident() ||
        hasPermission('canManageExecutives');
    }

    function canManageRegionalExecutiveLink(region) {
      return hasRole('super_admin') ||
        isNationalPresident() ||
        hasPermission('canManageExecutives') ||
        (
          isRegionalPresident() &&
          isSameRegion(region)
        );
    }

    function isRegionExecutiveIdsUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name',
        'executiveIds',
        'updatedAt'
      ]);
    }

    function canCreateEvents() {
      return hasRole('super_admin') ||
        isNationalPresident() ||
        isNationalSecretary() ||
        isRegionalPresident() ||
        isRegionalSecretary() ||
        hasPermission('canCreateEvents');
    }

    function canSuspendMembers() {
      return hasRole('super_admin') ||
        isNationalPresident() ||
        hasPermission('canSuspendMembers');
    }

    function canReadMeeting(meeting) {
      return isAuthenticated() && (
        meeting.visibility == 'public' ||
        meeting.visibility == 'members' ||
        (meeting.visibility == 'executives' && hasAnyRole(['regional_executive', 'national_executive', 'super_admin'])) ||
        (meeting.type == 'national' && hasRole('national_executive')) ||
        (meeting.type == 'regional' && (
          (meeting.visibility == 'regional' && isSameRegion(meeting.region)) ||
          (hasRole('regional_executive') && isSameRegion(meeting.region)) ||
          hasAnyRole(['national_executive', 'super_admin'])
        )) ||
        meeting.hostUid == request.auth.uid
      );
    }

    function isParticipantCountUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'lastJoinedAt']) &&
             request.resource.data.participants == resource.data.participants + 1 &&
             request.resource.data.lastJoinedAt == request.time;
    }

    function hasVerifiedEmail() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function isAllowedProfileCompletionUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'fullName',
        'phone',
        'region',
        'gender',
        'dateOfBirth',
        'maritalStatus',
        'address',
        'employmentStatus',
        'currentWorkplace',
        'profilePictureUrl',
        'photoURL',
        'photoUrl',
        'nextOfKin',
        'mustCompleteProfile',
        'profileCompletionStatus',
        'profileCompletedAt',
        'updatedAt'
      ]) &&
      request.resource.data.uid == resource.data.uid &&
      request.resource.data.email == resource.data.email &&
      request.resource.data.role == resource.data.role &&
      request.resource.data.status == resource.data.status &&
      (
        request.resource.data.region == resource.data.region ||
        resource.data.mustCompleteProfile == true
      );
    }
    
    // Helper to check if user can approve members
    function canApproveMembership() {
      return isAuthenticated() && (
        canApproveMembers() ||
        (hasRole('regional_executive') && 
         currentUserData().keys().hasAny(['canApproveMembership']) &&
         currentUserData().canApproveMembership == true)
      );
    }
    
    // Users collection
    match /users/{userId} {
      // Queries (list): any authenticated user may query — needed for region member
      // counts on public/dashboard pages. Individual doc reads stay restricted.
      allow list: if isAuthenticated();
      allow get: if isAuthenticated() && (
        request.auth.uid == userId ||
        hasRole('super_admin') ||
        hasAnyRole(['national_executive']) ||
        (hasRole('regional_executive') && sameExecutiveRegion(resource.data))
      );
      
      // Allow self-registration only with non-privileged defaults
      allow create: if isAuthenticated() &&
                      hasVerifiedEmail() &&
                      request.auth.uid == userId &&
                      request.resource.data.uid == request.auth.uid &&
                      request.resource.data.email == request.auth.token.email &&
                      request.resource.data.role == 'member' &&
                      request.resource.data.status == 'pending';
      
      // Allow updates by user themselves (own profile) or admins.
      allow update: if (
                        // Profile completion path: admin-created leader accounts have
                        // mustCompleteProfile=true set by admin. Allow them to fill in
                        // profile fields without requiring verified email or strict field checks.
                        request.auth.uid == userId &&
                        resource.data.mustCompleteProfile == true &&
                        request.resource.data.mustCompleteProfile == false &&
                        request.resource.data.role == resource.data.role &&
                        request.resource.data.status == resource.data.status
                      ) ||
                      (
                        // Normal self-update path. isAllowedProfileCompletionUpdate already
                        // prevents changing role, status, uid, and email, so email verification
                        // is not required here — admin-created accounts must be able to update
                        // their profile and profile picture after completing onboarding.
                        request.auth.uid == userId &&
                        isAllowedProfileCompletionUpdate()
                      ) ||
                      canManageMembers() ||
                      (
                       hasRole('regional_executive') &&
                       (isRegionalPresident() || isRegionalSecretary() || hasPermission('canManageMembers')) &&
                       sameExecutiveRegion(resource.data)
                      ) ||
                      // Regional execs can update if approving members in their region
                      (hasRole('regional_executive') && 
                       resource.data.status == 'pending' && 
                       request.resource.data.status == 'active' &&
                       canApproveMembers() &&
                       sameExecutiveRegion(resource.data));
      
      allow delete: if hasAnyRole(['super_admin']);
    }
    
    // Members collection
    match /members/{memberId} {
      // Queries (list): any authenticated user may query — needed for region counts.
      allow list: if isAuthenticated();
      allow get: if isAuthenticated() && (
        request.auth.uid == memberId ||
        hasRole('super_admin') ||
        hasAnyRole(['national_executive']) ||
        (hasRole('regional_executive') && sameExecutiveRegion(resource.data))
      );
      allow create: if isAuthenticated() &&
                      hasVerifiedEmail() &&
                      request.auth.uid == memberId &&
                      request.resource.data.uid == request.auth.uid &&
                      request.resource.data.email == request.auth.token.email &&
                      request.resource.data.role == 'member' &&
                      request.resource.data.status == 'pending'; // Allow on registration
      
      // Allow members to complete their own profile, and executives to approve/manage records
      allow update: if (
                        hasVerifiedEmail() &&
                        request.auth.uid == memberId &&
                        isAllowedProfileCompletionUpdate()
                      ) ||
                      canManageMembers() ||
                      (
                        hasRole('regional_executive') &&
                        (isRegionalPresident() || isRegionalSecretary() || hasPermission('canManageMembers')) &&
                        sameExecutiveRegion(resource.data)
                      ) ||
                      (
                        hasRole('regional_executive') &&
                        canApproveMembers() &&
                        sameExecutiveRegion(resource.data)
                      );

      allow delete: if hasRole('super_admin');
    }
    
    // Regions collection
    match /regions/{regionId} {
      allow read: if true; // Public read
      
      // Write access for national executives (for approval permissions)
      allow create: if hasRole('super_admin') ||
        hasPermission('canCreateRegions') ||
        (
          canManageRegionalExecutiveLink(regionId) &&
          request.resource.data.keys().hasOnly(['name', 'executiveIds', 'updatedAt'])
        );
      allow update: if hasRole('super_admin') ||
        isNationalPresident() ||
        (
          canManageRegionalExecutiveLink(regionId) &&
          isRegionExecutiveIdsUpdate()
        );
      allow delete: if hasRole('super_admin');

      match /executives/{executiveId} {
        allow read: if isAuthenticated() && (
          hasRole('super_admin') ||
          hasAnyRole(['national_executive']) ||
          isSameRegion(regionId) ||
          resource.data.memberUid == request.auth.uid
        );
        allow create, update: if canManageRegionalExecutiveLink(regionId) &&
          request.resource.data.region == regionId &&
          request.resource.data.leaderId == executiveId;
        allow delete: if hasRole('super_admin') || isNationalPresident();
      }
    }
    
    // Events collection
    match /events/{eventId} {
      allow read: if true; // Public read
      allow create: if isAuthenticated() && canCreateEvents() && (
        hasAnyRole(['super_admin', 'national_executive']) ||
        (
          hasRole('regional_executive') &&
          request.resource.data.region == userRegion() &&
          request.resource.data.status in ['pending_approval', 'draft']
        )
      );
      allow update: if isAuthenticated() && (
        hasRole('super_admin') ||
        isNationalPresident() ||
        (
          hasRole('regional_executive') &&
          canCreateEvents() &&
          sameExecutiveRegion(resource.data) &&
          !(request.resource.data.status in ['approved', 'national_approved'])
        )
      );
      allow delete: if hasRole('super_admin') || isNationalPresident();
    }

    // AGM registrations - member registration and executive reporting
    match /agmRegistrations/{registrationId} {
      allow read: if isAuthenticated() && (
        resource.data.memberUid == request.auth.uid ||
        hasAnyRole(['super_admin', 'national_executive']) ||
        (hasRole('regional_executive') && resource.data.region == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region)
      );

      allow create: if isAuthenticated() &&
        hasVerifiedEmail() &&
        request.resource.data.memberUid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.eventId == 'agm-2026' &&
        request.resource.data.paymentStatus == 'pending';

      allow update: if isAuthenticated() && (
        (
          resource.data.memberUid == request.auth.uid &&
          resource.data.paymentStatus == 'pending' &&
          request.resource.data.memberUid == request.auth.uid &&
          request.resource.data.email == request.auth.token.email &&
          request.resource.data.paymentStatus == resource.data.paymentStatus
        ) ||
        hasAnyRole(['super_admin', 'national_executive']) ||
        (hasRole('regional_executive') && resource.data.region == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region)
      );

      allow delete: if hasAnyRole(['super_admin', 'national_executive']);
    }

    match /regions/{regionId}/members/{memberId} {
      allow read: if isAuthenticated() && (
        memberId == request.auth.uid ||
        hasAnyRole(['super_admin', 'national_executive']) ||
        (hasRole('regional_executive') && resource.data.region == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region)
      );

      allow create, update: if isAuthenticated() &&
        hasVerifiedEmail() &&
        memberId == request.auth.uid &&
        request.resource.data.email == request.auth.token.email;
      allow delete: if hasAnyRole(['super_admin', 'national_executive']);
    }

    // Publicly readable aggregate stats (region member counts etc.)
    match /publicStats/{docId} {
      allow read: if true;
      allow write: if false; // Cloud Functions only
    }

    match /publicRegionMembers/{regionId}/members/{memberId} {
      allow read: if true;
      allow create, update: if isAuthenticated() &&
        hasVerifiedEmail() &&
        memberId == request.auth.uid &&
        request.resource.data.keys().hasOnly(['uid', 'region', 'regionId', 'status', 'updatedAt']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.regionId == regionId;
      allow delete: if hasAnyRole(['super_admin', 'national_executive']);
    }

    match /regions/{regionId}/agmRegistrations/{registrationId} {
      allow read: if isAuthenticated() && (
        resource.data.memberUid == request.auth.uid ||
        hasAnyRole(['super_admin', 'national_executive']) ||
        (hasRole('regional_executive') && resource.data.region == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region)
      );

      allow create: if isAuthenticated() &&
        hasVerifiedEmail() &&
        request.resource.data.memberUid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.eventId == 'agm-2026' &&
        request.resource.data.paymentStatus == 'pending';

      allow update: if isAuthenticated() && (
        (
          resource.data.memberUid == request.auth.uid &&
          resource.data.paymentStatus == 'pending' &&
          request.resource.data.memberUid == request.auth.uid &&
          request.resource.data.email == request.auth.token.email &&
          request.resource.data.paymentStatus == resource.data.paymentStatus
        ) ||
        hasAnyRole(['super_admin', 'national_executive']) ||
        (hasRole('regional_executive') && resource.data.region == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region)
      );

      allow delete: if hasAnyRole(['super_admin', 'national_executive']);
    }
    
    // Payments collection
    match /payments/{paymentId} {
      // Read: User can read their own payments, executives can read all
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        resource.data.memberUid == request.auth.uid ||
        canViewNationalPayments() ||
        (
          canViewRegionalPayments() &&
          sameExecutiveRegion(resource.data)
        )
      );
      
      // Create: Members can create their own payments through Cloud Functions
      // Direct creation is blocked - must use processDuesPayment function
      allow create: if false; // Only Cloud Functions can create payments
      
      // Update: Only admins can update payments (for corrections/waivers)
      allow update: if hasRole('super_admin') ||
                       (canManagePayments() && canViewNationalPayments()) ||
                       (canManagePayments() && sameExecutiveRegion(resource.data));
      
      allow delete: if hasAnyRole(['super_admin']);
    }
    
    // Certificates collection (public read for verification)
    match /certificates/{certId} {
      allow read: if true; // Public verification
      allow write: if hasAnyRole(['super_admin', 'national_executive']);
    }
    
    // News and announcements (public read)
    match /news/{newsId} {
      allow read: if true;
      allow write: if hasRole('super_admin') ||
        isNationalPresident() ||
        isNationalSecretary() ||
        (
          hasRole('regional_executive') &&
          (isRegionalPresident() || isRegionalSecretary() || hasPermission('canBroadcastMessages')) &&
          request.resource.data.region == userRegion()
        ) ||
        hasPermission('canBroadcastMessages');
    }
    
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if hasRole('super_admin') ||
        isNationalPresident() ||
        isNationalSecretary() ||
        hasPermission('canBroadcastMessages');
    }
    
    // Gallery and videos (public read)
    match /gallery/{photoId} {
      allow read: if true;
      allow write: if hasAnyRole(['super_admin', 'national_executive', 'regional_executive']);
    }
    
    match /videos/{videoId} {
      allow read: if true;
      allow write: if hasAnyRole(['super_admin', 'national_executive', 'regional_executive']);
    }
    
    // Leadership (public read)
    match /leadership/{leaderId} {
      allow read: if true;
      allow create: if hasRole('super_admin') ||
        isNationalPresident() ||
        (
          isRegionalPresident() &&
          request.resource.data.region == userRegion() &&
          request.resource.data.status == 'pending_national_approval'
        ) ||
        hasPermission('canManageExecutives');
      allow update: if hasRole('super_admin') ||
        isNationalPresident() ||
        (
          isRegionalPresident() &&
          sameExecutiveRegion(resource.data) &&
          request.resource.data.status in ['pending_national_approval', 'pending_approval', 'inactive']
        );
      allow delete: if hasRole('super_admin');
    }

    // Executive governance records
    match /leaders/{leaderId} {
      allow read: if isAuthenticated() && (
        hasRole('super_admin') ||
        hasAnyRole(['national_executive']) ||
        sameExecutiveRegion(resource.data) ||
        resource.data.memberUid == request.auth.uid ||
        resource.data.createdBy.uid == request.auth.uid
      );
      allow create: if hasRole('super_admin') ||
        isNationalPresident() ||
        (
          isRegionalPresident() &&
          request.resource.data.region == userRegion() &&
          request.resource.data.status == 'pending_national_approval'
        ) ||
        hasPermission('canManageExecutives');
      allow update: if hasRole('super_admin') ||
        isNationalPresident() ||
        (
          isRegionalPresident() &&
          sameExecutiveRegion(resource.data) &&
          request.resource.data.region == userRegion() &&
          request.resource.data.status == 'pending_national_approval'
        );
      allow delete: if hasRole('super_admin');
    }

    match /regionalExecutives/{executiveId} {
      allow read: if isAuthenticated() && (
        hasRole('super_admin') ||
        hasAnyRole(['national_executive']) ||
        sameExecutiveRegion(resource.data) ||
        resource.data.createdBy.uid == request.auth.uid
      );
      allow create: if hasRole('super_admin') ||
        isNationalPresident() ||
        (
          isRegionalPresident() &&
          request.resource.data.region == userRegion() &&
          request.resource.data.status == 'pending_national_approval'
        ) ||
        hasPermission('canManageExecutives');
      allow update: if hasRole('super_admin') ||
        isNationalPresident() ||
        (
          isRegionalPresident() &&
          sameExecutiveRegion(resource.data) &&
          request.resource.data.region == userRegion() &&
          request.resource.data.status == 'pending_national_approval'
        );
      allow delete: if hasRole('super_admin');
    }

    match /districtExecutives/{executiveId} {
      allow read: if isAuthenticated() && (
        hasRole('super_admin') ||
        hasAnyRole(['national_executive']) ||
        sameExecutiveRegion(resource.data) ||
        resource.data.memberUid == request.auth.uid ||
        resource.data.createdBy.uid == request.auth.uid
      );
      allow create: if hasRole('super_admin') ||
        isNationalPresident() ||
        (
          isRegionalPresident() &&
          request.resource.data.region == userRegion() &&
          request.resource.data.status == 'pending_national_approval'
        ) ||
        hasPermission('canManageExecutives');
      allow update: if hasRole('super_admin') ||
        isNationalPresident() ||
        (
          isRegionalPresident() &&
          sameExecutiveRegion(resource.data) &&
          request.resource.data.region == userRegion() &&
          request.resource.data.status == 'pending_national_approval'
        );
      allow delete: if hasRole('super_admin');
    }

    match /nationalExecutives/{executiveId} {
      allow read: if isAuthenticated() && (
        hasRole('super_admin') ||
        hasAnyRole(['national_executive']) ||
        resource.data.createdBy.uid == request.auth.uid
      );
      allow create, update: if hasRole('super_admin') ||
        isNationalPresident() ||
        hasPermission('canManageExecutives');
      allow delete: if hasRole('super_admin');
    }

    // Executive approval workflow
    match /executive_requests/{requestId} {
      allow read: if isAuthenticated() && (
        hasRole('super_admin') ||
        hasAnyRole(['national_executive']) ||
        (
          hasRole('regional_executive') &&
          sameExecutiveRegion(resource.data)
        ) ||
        resource.data.createdBy == request.auth.uid
      );

      allow create: if isAuthenticated() && (
        hasRole('super_admin') ||
        isNationalPresident() ||
        (
          isRegionalPresident() &&
          request.resource.data.region == userRegion() &&
          request.resource.data.status == 'pending_national_approval'
        )
      );

      allow update: if hasRole('super_admin') || isNationalPresident();
      allow delete: if hasRole('super_admin');
    }
    
    // Leadership Terms - Election tracking
    match /leadership_terms/{termId} {
      allow read: if request.auth != null; // All authenticated users can view terms
      allow create: if hasAnyRole(['super_admin', 'national_executive']);
      allow update: if hasAnyRole(['super_admin', 'national_executive']);
      allow delete: if hasAnyRole(['super_admin']);
    }
    
    // Committees collection
    match /committees/{committeeId} {
      allow read: if request.auth != null;
      allow write: if hasRole('super_admin') || isNationalPresident() || hasPermission('canManageExecutives');
    }
    
    // Dues collection
    match /dues/{duesId} {
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        canViewNationalPayments() ||
        (canViewRegionalPayments() && sameExecutiveRegion(resource.data))
      );
      allow create: if request.auth != null;
      allow update: if hasRole('super_admin') || isNationalTreasurer() || hasPermission('canManagePayments');
    }
    
    // Contributions collection
    match /contributions/{contributionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if hasAnyRole(['super_admin', 'national_executive']);
    }
    
    // ===== SECURITY COMMAND CENTER COLLECTIONS =====
    
    // Security Events - Append-only audit log
    match /security_events/{eventId} {
      allow read: if hasAnyRole(['super_admin']);
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Security Alerts - System-generated alerts
    match /security_alerts/{alertId} {
      allow read: if hasAnyRole(['super_admin']);
      allow create: if false; // Only Cloud Functions
      allow update: if hasAnyRole(['super_admin']); // Allow ack/resolve
      allow delete: if hasAnyRole(['super_admin']);
    }
    
    // Security Profiles - Admin risk profiles
    match /security_profiles/{profileId} {
      allow read: if hasAnyRole(['super_admin']);
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Security Controls - Kill switches
    match /security_controls/{controlId} {
      allow read: if hasAnyRole(['super_admin']);
      allow write: if hasAnyRole(['super_admin']); // Admins can block/unblock
    }
    
    // Security Settings - Configurable thresholds
    match /security_settings/{settingId} {
      allow read: if hasAnyRole(['super_admin']);
      allow write: if hasAnyRole(['super_admin']);
    }
    
    // Audit Logs - Comprehensive action logs
    match /audit_logs/{logId} {
      allow read: if hasRole('super_admin') || isNationalPresident() || hasPermission('canViewAuditLogs');
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Admin Security - Rate limiting data
    match /admin_security/{adminId} {
      allow read: if hasAnyRole(['super_admin']);
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Notifications - User notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null && 
                     resource.data.uid == request.auth.uid;
      allow create: if false; // Only Cloud Functions
      allow update: if request.auth != null && 
                       resource.data.uid == request.auth.uid; // Allow marking as read
      allow delete: if request.auth != null && 
                       resource.data.uid == request.auth.uid;
    }
    
    // System Logs - Automated system logs (cron jobs, scheduled tasks)
    match /system_logs/{logId} {
      allow read: if hasRole('super_admin') || hasPermission('canManageSystemSettings');
      allow write: if false; // Only Cloud Functions and scheduled tasks
    }
    
    // Waiver Requests - Member waiver requests for overdue dues
    match /waiver_requests/{requestId} {
      // Read: Members can read their own requests, regional execs can read requests from their region, national execs can read all
      allow read: if request.auth != null && (
        resource.data.memberUid == request.auth.uid ||
        (isRole('regional_executive') && 
         resource.data.region == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region) ||
        hasAnyRole(['super_admin', 'national_executive'])
      );
      
      // Create: Members can create their own waiver requests
      allow create: if request.auth != null && 
                       request.auth.uid == request.resource.data.memberUid &&
                       request.resource.data.status == 'pending';
      
      // Update: Only Cloud Functions can update (review approval/rejection)
      allow update: if false; // Must use reviewWaiverRequest Cloud Function
      
      allow delete: if hasAnyRole(['super_admin']);
    }
    
    // Suspensions - User and regional suspensions (Super Admin only)
    match /suspensions/{suspensionId} {
      // Read: Super admins can read all, users can read their own suspensions
      allow read: if request.auth != null && (
        hasAnyRole(['super_admin', 'national_executive']) ||
        resource.data.targetUid == request.auth.uid
      );
      
      // Write: Only Cloud Functions can create/update suspensions
      allow create: if false; // Must use suspendUser/suspendRegion Cloud Functions
      allow update: if false; // Must use unsuspendUser/unsuspendRegion Cloud Functions
      
      allow delete: if hasAnyRole(['super_admin']);
    }
    
    // ===== DONATION SYSTEM COLLECTIONS =====
    
    // Donations - Monetary and material donations
    match /donations/{donationId} {
      // Read: Donors can read their own donations, regional execs can read donations from their region, national execs can read all
      // Public visibility donations can be read by anyone when visibility is public
      allow read: if request.auth != null && (
        (resource.data.keys().hasAny(['donorId']) && resource.data.donorId == request.auth.uid) ||
        (resource.data.keys().hasAny(['donorUid']) && resource.data.donorUid == request.auth.uid) ||
        (isRole('regional_executive') && 
         resource.data.donorRegion == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region) ||
        hasAnyRole(['super_admin', 'national_executive']) ||
        (resource.data.visibility == 'public' && resource.data.status in ['confirmed', 'distributed']) ||
        (resource.data.visibility == 'members_only' && resource.data.status in ['confirmed', 'distributed'])
      );
      
      // Create: Only through submitDonation Cloud Function
      allow create: if false; // Must use submitDonation callable function
      
      // Update: Only Cloud Functions can update (for confirmation and distribution)
      allow update: if false; // Must use confirmDonationReceipt or recordDonationDistribution functions
      
      allow delete: if hasAnyRole(['super_admin']);
    }
    
    // Donation Campaigns - Fundraising campaigns
    match /donation_campaigns/{campaignId} {
      // Read: Public campaigns are readable by all, restricted campaigns by authenticated users
      allow read: if (resource.data.visibility == 'public') || 
                     (request.auth != null && resource.data.visibility == 'members_only') ||
                     (request.auth != null && hasAnyRole(['super_admin', 'national_executive', 'regional_executive']));
      
      // Create: National executives can create campaigns
      allow create: if hasAnyRole(['super_admin', 'national_executive']);
      
      // Update: Campaign creators and national executives can update
      allow update: if hasAnyRole(['super_admin', 'national_executive']) ||
                       (request.auth != null && resource.data.createdBy == request.auth.uid);
      
      allow delete: if hasAnyRole(['super_admin', 'national_executive']);
    }
    
    // Distribution Records - Photos and details of donation distributions
    match /distributions/{distributionId} {
      // Read: Same visibility as donations
      allow read: if request.auth != null && (
        (resource.data.keys().hasAny(['donorId']) && resource.data.donorId == request.auth.uid) ||
        (resource.data.keys().hasAny(['donorUid']) && resource.data.donorUid == request.auth.uid) ||
        hasAnyRole(['super_admin', 'national_executive', 'regional_executive']) ||
        (resource.data.visibility == 'public') ||
        (resource.data.visibility == 'members_only')
      );
      
      // Create: Only Cloud Functions can create distribution records
      allow create: if false; // Must use recordDonationDistribution function
      
      // Update: Regional and national execs can update distributions in their region
      allow update: if hasAnyRole(['super_admin', 'national_executive']) ||
                       (isRole('regional_executive') && 
                        resource.data.region == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.region);
      
      allow delete: if hasAnyRole(['super_admin', 'national_executive']);
    }

    // ===== MEETINGS COLLECTION =====
    match /meetings/{meetingId} {
      // List (collection queries): allow any authenticated user — the query already
      // filters by type/region server-side, so users only receive their own meetings.
      // Chained get() calls inside canReadMeeting exceed Firestore's rule evaluation
      // limit when used on queries, causing "Missing or insufficient permissions".
      allow list: if isAuthenticated();
      // Single-doc reads retain the full visibility check.
      allow get: if canReadMeeting(resource.data);
      
      // Create: Only through Cloud Function
      allow create: if false;
      
      // Update: Only host, regional secretary, or national exec
      allow update: if isAuthenticated() && (
        resource.data.hostUid == request.auth.uid ||
        (hasRole('regional_executive') && resource.data.type == 'regional' && isSameRegion(resource.data.region)) ||
        hasAnyRole(['national_executive', 'super_admin']) ||
        (canReadMeeting(resource.data) && isParticipantCountUpdate())
      );
      
      // Delete: Only host or national exec
      allow delete: if isAuthenticated() && (
        resource.data.hostUid == request.auth.uid ||
        hasAnyRole(['national_executive', 'super_admin'])
      );
    }

    // ===== MEETING ATTENDANCE COLLECTION =====
    match /meeting_attendance/{attendanceId} {
      // Read: Meeting host, attendees, and admins
      allow read: if isAuthenticated();
      
      // Create: Authenticated users can track their own attendance
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Update/Delete: Only admins
      allow update, delete: if hasAnyRole(['national_executive', 'super_admin']);
    }

    // ===== MEETING NOTES COLLECTION =====
    match /meeting_notes/{noteId} {
      // Read: Meeting participants and admins
      allow read: if isAuthenticated();
      
      // Create: Authenticated users can create notes
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Update: Only note creator or admins
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        hasAnyRole(['national_executive', 'super_admin'])
      );
      
      // Delete: Only note creator or admins
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        hasAnyRole(['national_executive', 'super_admin'])
      );
    }
  }
}
